\uc0\u26368 \u21518 \u25105 \u20204 \u32771 \u23519 \u65306 \u22522 \u20110 \u35266 \u27979 \u30340 \u21518 \u39564 \u25512 \u26029 \u33021 \u21542 \u23558 \u24212 \u21147 \u32422 \u26463 \u36716 \u21270 \u20026 \u21442 \u25968 \u31354 \u38388 \u20013 \u30340 \u21487 \u34892 \u22495 \u25910 \u32553 \u12290 \u24403 \u21069  reduced inverse benchmark \u22312  20 \u20010 \u29420 \u31435  hold-out synthetic case \u19978 \u36827 \u34892 \u65292 \u24182 \u20165 \u21453 \u28436  4 \u20010 \u26657 \u20934 \u21442 \u25968 \u12304 \u35201 \u35828 \u28165 \u26970 \u21738 4\u20010 \u12305 \u12290 \u22312 \u36825 \u20123  case \u19978 \u65292 \u24179 \u22343 \u25509 \u21463 \u29575 \u20026  0.628\u65292 \u24179 \u22343 \u35266 \u27979 \u25311 \u21512 \u32477 \u23545 \u35823 \u24046 \u20026  1.227\u65292 \u24179 \u22343  observable coverage90 \u20026  1.0\u12290 \u22312  131 MPa \u38408 \u20540 \u19979 \u65292 \u21518 \u39564 \u23433 \u20840 \u21487 \u34892 \u22495 \u30340 \u24179 \u22343 \u27604 \u20363 \u20026  0.1667\u65307 \u24403 \u38408 \u20540 \u25910 \u32039 \u21040  120 MPa \u19982  110 MPa \u26102 \u65292 \u36825 \u19968 \u27604 \u20363 \u36827 \u19968 \u27493 \u38477 \u33267  0.0792 \u19982  0.0373\u12290 \u36825 \u20123 \u24179 \u22343 \u32467 \u26524 \u24050 \u32463 \u34920 \u26126 \u65292 \u36234 \u20005 \u26684 \u30340 \u23433 \u20840 \u35201 \u27714 \u20250 \u26174 \u33879 \u21387 \u32553 \u21518 \u39564 \u20013 \u30340 \u21487 \u25509 \u21463 \u21442 \u25968 \u21306 \u22495 \u12290 \u12304 \u30446 \u21069 \u19978 \u20256 \u30340 \u27604 \u36739 \u34920 \u21482 \u21253 \u21547  reduced \u32467 \u26524 \u65307 \u33509 \u21518 \u32493 \u34917 \u20805  full inverse benchmark\u65292 \u36825 \u19968 \u27573 \u24212 \u21319 \u32423 \u20026  full \u19982  reduced \u30340 \u27491 \u24335 \u23545 \u27604 \u12290 \u21999 \u21999 \u35201 \u34917 \u20805 \u30340 \u12305  \u12304 \u36825 \u20010 \u19977 \u20010 \u38408 \u20540 \u23545 \u27604 \u19981 \u35201 \u20889 \u22312 \u