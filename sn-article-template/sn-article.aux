\@writefile{lof}{\contentsline {figure}{\numberline {E3}{\ignorespaces Surrogate calibration diagnostics for the coupled steady-state maximum global stress output (\texttt  {data-mono-ineq}, test set $n=435$). (A)~Reliability diagram: empirical prediction interval coverage probability (PICP) vs.\ nominal confidence level; the curve closely follows the ideal diagonal (dashed), confirming well-calibrated predictive uncertainty. (B)~Mean prediction interval width as a~function of nominal coverage. }}{24}{figure.3}\protected@file@percent }
\newlabel{fig:calibration}{{E3}{24}{Surrogate calibration diagnostics for the coupled steady-state maximum global stress output (\texttt {data-mono-ineq}, test set $n=435$). (A)~Reliability diagram: empirical prediction interval coverage probability (PICP) vs.\ nominal confidence level; the curve closely follows the ideal diagonal (dashed), confirming well-calibrated predictive uncertainty. (B)~Mean prediction interval width as a~function of nominal coverage}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {E4}{\ignorespaces Heteroscedastic predictive uncertainty for the coupled steady-state maximum global stress (\texttt  {data-mono-ineq}, test set). (A)~Predicted standard deviation $\sigma $ as a~function of predicted mean, coloured by true stress; $\sigma $ increases in the high-stress regime, reflecting the model's recognition of higher aleatoric uncertainty in extreme parameter regions. (B)~Distribution of predicted $\sigma $ across test samples. }}{24}{figure.4}\protected@file@percent }
\newlabel{fig:hetero_sigma}{{E4}{24}{Heteroscedastic predictive uncertainty for the coupled steady-state maximum global stress (\texttt {data-mono-ineq}, test set). (A)~Predicted standard deviation $\sigma $ as a~function of predicted mean, coloured by true stress; $\sigma $ increases in the high-stress regime, reflecting the model's recognition of higher aleatoric uncertainty in extreme parameter regions. (B)~Distribution of predicted $\sigma $ across test samples}{figure.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {E5}{\ignorespaces Per-output accuracy for all 15 physics outputs (\texttt  {data-mono-ineq} surrogate, test set). (A)~$R^2$; (B)~90\% prediction interval coverage (PICP$_{90}$). Blue bars: coupled steady-state outputs; light-blue bars: decoupled (decoupled single-pass) outputs. Wall expansion achieves $R^2=0.998$; coupled temperature outputs show lower $R^2\approx 0.66$, reflecting their weaker sensitivity to the 8~material inputs in the coupled regime. }}{25}{figure.5}\protected@file@percent }
\newlabel{fig:per_output}{{E5}{25}{Per-output accuracy for all 15 physics outputs (\texttt {data-mono-ineq} surrogate, test set). (A)~$R^2$; (B)~90\% prediction interval coverage (PICP$_{90}$). Blue bars: coupled steady-state outputs; light-blue bars: decoupled (decoupled single-pass) outputs. Wall expansion achieves $R^2=0.998$; coupled temperature outputs show lower $R^2\approx 0.66$, reflecting their weaker sensitivity to the 8~material inputs in the coupled regime}{figure.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {E6}{\ignorespaces Prior predictive (grey) vs.\ posterior predictive (blue) stress distributions for four representative benchmark cases (coupled steady-state max global stress). The observed stress (red dashed) and design threshold (orange dotted, \SI {131}{MPa}) are indicated. Posterior updating concentrates probability mass near the observed value in all four cases, including the high-stress and extreme-stress scenarios. }}{25}{figure.6}\protected@file@percent }
\newlabel{fig:prior_post_pred}{{E6}{25}{Prior predictive (grey) vs.\ posterior predictive (blue) stress distributions for four representative benchmark cases (coupled steady-state max global stress). The observed stress (red dashed) and design threshold (orange dotted, \SI {131}{MPa}) are indicated. Posterior updating concentrates probability mass near the observed value in all four cases, including the high-stress and extreme-stress scenarios}{figure.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {E7}{\ignorespaces Schematic of the heteroscedastic multilayer perceptron~(HeteroMLP) architecture. The 8-dimensional material parameter vector $\bm  {\theta }$ passes through shared hidden layers (width 143, depth 3 for Regularized) and is decoded into two heads: a~mean output $\bm  {\mu }$ and a~log-variance output $\log \bm  {\sigma }^2$, each of dimension~15. In the \texttt  {data-mono-ineq} variant, both Spearman-rank monotonicity ($\mathcal  {L}_{\mathrm  {mono}}$, Eq.~\ref {eq:mono}) and physical-inequality constraints are applied during training. }}{26}{figure.7}\protected@file@percent }
\newlabel{fig:bnn_schematic}{{E7}{26}{Schematic of the heteroscedastic multilayer perceptron~(HeteroMLP) architecture. The 8-dimensional material parameter vector $\bm {\theta }$ passes through shared hidden layers (width 143, depth 3 for Regularized) and is decoded into two heads: a~mean output $\bm {\mu }$ and a~log-variance output $\log \bm {\sigma }^2$, each of dimension~15. In the \texttt {data-mono-ineq} variant, both Spearman-rank monotonicity ($\mathcal {L}_{\mathrm {mono}}$, Eq.~\ref {eq:mono}) and physical-inequality constraints are applied during training}{figure.7}{}}
