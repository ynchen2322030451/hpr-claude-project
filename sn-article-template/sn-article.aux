\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Surrogate accuracy on the held-out test set ($n=435$). (A)~Parity plot for coupled steady-state maximum global stress ($R^2=0.941$, RMSE~$=\SI {7.4}{MPa}$); (B)~$R^2$ for all five primary outputs comparing the baseline and the \texttt  {data-mono-ineq} regularized surrogate; (C)~OOD robustness for $\alpha _{\mathrm  {base}}$ extrapolation: the combined monotonicity and physical-inequality regularization provides $\Delta R^2 \approx +0.17$ for the stress response. }}{5}{figure.2}\protected@file@percent }
\newlabel{fig:accuracy}{{2}{5}{Surrogate accuracy on the held-out test set ($n=435$). (A)~Parity plot for coupled steady-state maximum global stress ($R^2=0.941$, RMSE~$=\SI {7.4}{MPa}$); (B)~$R^2$ for all five primary outputs comparing the baseline and the \texttt {data-mono-ineq} regularized surrogate; (C)~OOD robustness for $\alpha _{\mathrm {base}}$ extrapolation: the combined monotonicity and physical-inequality regularization provides $\Delta R^2 \approx +0.17$ for the stress response}{figure.2}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Out-of-distribution~(OOD) evaluation: coupled steady-state stress $R^2$ for held-out samples with extreme values of each input feature. The regularized model shows the largest improvement for $\alpha _{\mathrm  {base}}$ extrapolation ($\Delta R^2 = +0.170$). }}{5}{table.2}\protected@file@percent }
\newlabel{tab:ood}{{2}{5}{Out-of-distribution~(OOD) evaluation: coupled steady-state stress $R^2$ for held-out samples with extreme values of each input feature. The regularized model shows the largest improvement for $\alpha _{\mathrm {base}}$ extrapolation ($\Delta R^2 = +0.170$)}{table.2}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Comparison of decoupled single-pass and coupled steady-state uncertainty distributions for the stress and $k_{\mathrm  {eff}}$ outputs, from \num {20000} prior Monte~Carlo samples through the \texttt  {data-mono-ineq} surrogate at $\sigma _{k}=1$ (epistemic, mean predictions). The coupled stress mean is obtained directly from forward UQ around the nominal design; the decoupled iter-1 stress level is inferred from the same samples via the learned $\text  {iter}_1\!\to \!\text  {iter}_2$ delta (Section~\ref {sec:forward_uq}). Extended threshold results (including \SI {169}{} and \SI {200}{MPa}) are in Supplementary Table~\ref {tab:forward_uq_appendix}. }}{6}{table.3}\protected@file@percent }
\newlabel{tab:forward_uq}{{3}{6}{Comparison of decoupled single-pass and coupled steady-state uncertainty distributions for the stress and $k_{\mathrm {eff}}$ outputs, from \num {20000} prior Monte~Carlo samples through the \texttt {data-mono-ineq} surrogate at $\sigma _{k}=1$ (epistemic, mean predictions). The coupled stress mean is obtained directly from forward UQ around the nominal design; the decoupled iter-1 stress level is inferred from the same samples via the learned $\text {iter}_1\!\to \!\text {iter}_2$ delta (Section~\ref {sec:forward_uq}). Extended threshold results (including \SI {169}{} and \SI {200}{MPa}) are in Supplementary Table~\ref {tab:forward_uq_appendix}}{table.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Forward uncertainty propagation: effect of multi-physics coupling on output distributions (\num {20000} prior Monte~Carlo samples, \texttt  {data-mono-ineq} surrogate, epistemic mean predictions). (A)~Max global stress: coupling shifts the mean from approximately \SI {205.0}{MPa} (decoupled iter-1) to \SI {162.6}{MPa} (coupled iter-2) and reduces the $1\sigma $ spread by about~29\%, reflecting the neutronics--thermal negative feedback described in Section~\ref {sec:hf}. (B,~C)~$k_{\mathrm  {eff}}$ distributions before and after coupling; the coupled distribution is approximately two orders of magnitude narrower than the decoupled one. Both panels in each comparison share axes. }}{6}{figure.3}\protected@file@percent }
\newlabel{fig:forward_uq}{{3}{6}{Forward uncertainty propagation: effect of multi-physics coupling on output distributions (\num {20000} prior Monte~Carlo samples, \texttt {data-mono-ineq} surrogate, epistemic mean predictions). (A)~Max global stress: coupling shifts the mean from approximately \SI {205.0}{MPa} (decoupled iter-1) to \SI {162.6}{MPa} (coupled iter-2) and reduces the $1\sigma $ spread by about~29\%, reflecting the neutronics--thermal negative feedback described in Section~\ref {sec:hf}. (B,~C)~$k_{\mathrm {eff}}$ distributions before and after coupling; the coupled distribution is approximately two orders of magnitude narrower than the decoupled one. Both panels in each comparison share axes}{figure.3}{}}
