\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Architecture of the heteroscedastic MLP (HeteroMLP) surrogate. A~shared backbone maps the 8-dimensional material parameter vector $\bm  {\theta }$ to twin output heads that jointly predict the mean $\bm  {\mu }(\bm  {\theta })$ and log-variance $\log \bm  {\sigma }^2(\bm  {\theta })$ for all 15 physics outputs. The monotone-regularized variant (Section~\ref {sec:results_accuracy}) adds a~Spearman-rank penalty term (Eq.~\eqref  {eq:mono}) to enforce physics-consistent monotonicity constraints during training. }}{15}{figure.7}\protected@file@percent }
\newlabel{fig:architecture}{{7}{15}{Architecture of the heteroscedastic MLP (HeteroMLP) surrogate. A~shared backbone maps the 8-dimensional material parameter vector $\bm {\theta }$ to twin output heads that jointly predict the mean $\bm {\mu }(\bm {\theta })$ and log-variance $\log \bm {\sigma }^2(\bm {\theta })$ for all 15 physics outputs. The monotone-regularized variant (Section~\ref {sec:results_accuracy}) adds a~Spearman-rank penalty term (Eq.~\eqref {eq:mono}) to enforce physics-consistent monotonicity constraints during training}{figure.7}{}}
\newlabel{eq:pexceed}{{3}{15}{Forward uncertainty propagation}{equation.3}{}}
