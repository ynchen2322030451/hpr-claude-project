\@writefile{lof}{\contentsline {figure}{\numberline {E1}{\ignorespaces MCMC posterior trace plots for four representative \texttt  {data-mono-ineq} benchmark cases: low stress (observed $\approx \SI {110}{MPa}$), near-threshold ($\approx \SI {129}{MPa}$), high stress ($\approx \SI {193}{MPa}$), and a~feasible-region probe case ($\approx \SI {185}{MPa}$, drawn from the high-stress feasibility sweep). Rows correspond to the four calibrated parameters ($E_{\mathrm  {intercept}}$, $\alpha _{\mathrm  {base}}$, $\alpha _{\mathrm  {slope}}$, $\nu $); columns to cases. Visual inspection confirms adequate chain mixing in all cases (acceptance rates 0.49--0.59). }}{22}{figure.1}\protected@file@percent }
\newlabel{fig:mcmc_trace}{{E1}{22}{MCMC posterior trace plots for four representative \texttt {data-mono-ineq} benchmark cases: low stress (observed $\approx \SI {110}{MPa}$), near-threshold ($\approx \SI {129}{MPa}$), high stress ($\approx \SI {193}{MPa}$), and a~feasible-region probe case ($\approx \SI {185}{MPa}$, drawn from the high-stress feasibility sweep). Rows correspond to the four calibrated parameters ($E_{\mathrm {intercept}}$, $\alpha _{\mathrm {base}}$, $\alpha _{\mathrm {slope}}$, $\nu $); columns to cases. Visual inspection confirms adequate chain mixing in all cases (acceptance rates 0.49--0.59)}{figure.1}{}}
