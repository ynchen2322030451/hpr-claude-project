\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces First-order Sobol indices $S_1$ (90\% CI) for coupled steady-state maximum global stress and $k_{\mathrm  {eff}}$ (\texttt  {data-mono-ineq} surrogate). Only factors with CI not including zero are listed; full results in Appendix~\ref {sec:appendix_sobol}. }}{8}{table.4}\protected@file@percent }
\newlabel{tab:sobol}{{4}{8}{First-order Sobol indices $S_1$ (90\% CI) for coupled steady-state maximum global stress and $k_{\mathrm {eff}}$ (\texttt {data-mono-ineq} surrogate). Only factors with CI not including zero are listed; full results in Appendix~\ref {sec:appendix_sobol}}{table.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Global Sobol first-order sensitivity analysis (\texttt  {data-mono-ineq} surrogate; $N_S=\num {4096}$; 90\% CI, 50 independent replications). (A)~First-order indices for coupled steady-state max global stress: $E_{\mathrm  {intercept}}$ is the dominant driver ($S_1=0.586$); diamond markers show the baseline (Baseline) attribution for comparison. (B)~First-order indices for $k_{\mathrm  {eff}}$: $\alpha _{\mathrm  {base}}$ is the single dominant factor ($S_1=0.771$). Grey bars indicate inputs whose 90\% CI includes zero. The two outputs are governed by distinct physical pathways (Section~\ref {sec:hf}): elastic stiffness governs stress, thermal expansion governs reactivity. }}{8}{figure.4}\protected@file@percent }
\newlabel{fig:sobol}{{4}{8}{Global Sobol first-order sensitivity analysis (\texttt {data-mono-ineq} surrogate; $N_S=\num {4096}$; 90\% CI, 50 independent replications). (A)~First-order indices for coupled steady-state max global stress: $E_{\mathrm {intercept}}$ is the dominant driver ($S_1=0.586$); diamond markers show the baseline (Baseline) attribution for comparison. (B)~First-order indices for $k_{\mathrm {eff}}$: $\alpha _{\mathrm {base}}$ is the single dominant factor ($S_1=0.771$). Grey bars indicate inputs whose 90\% CI includes zero. The two outputs are governed by distinct physical pathways (Section~\ref {sec:hf}): elastic stiffness governs stress, thermal expansion governs reactivity}{figure.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Observation-driven posterior calibration results (\texttt  {data-mono-ineq} surrogate; 18~benchmark cases, 4 calibrated parameters, 1200 effective posterior samples per case). (A)~Posterior mean stress prediction vs.\ true stress for the 18~benchmark test cases (nearest-neighbour HF proxy validation); posterior predictions closely track the diagonal. (B)~Posterior exceedance probabilities $P(\sigma >\SI {131}{MPa}\mid \mathrm  {obs})$ for the 10~high-stress feasible-region cases (true stress 133--\SI {194}{MPa}); all 10~cases are classified as high-risk (above the global prior of approximately $0.85$). }}{9}{figure.5}\protected@file@percent }
\newlabel{fig:posterior}{{5}{9}{Observation-driven posterior calibration results (\texttt {data-mono-ineq} surrogate; 18~benchmark cases, 4 calibrated parameters, 1200 effective posterior samples per case). (A)~Posterior mean stress prediction vs.\ true stress for the 18~benchmark test cases (nearest-neighbour HF proxy validation); posterior predictions closely track the diagonal. (B)~Posterior exceedance probabilities $P(\sigma >\SI {131}{MPa}\mid \mathrm {obs})$ for the 10~high-stress feasible-region cases (true stress 133--\SI {194}{MPa}); all 10~cases are classified as high-risk (above the global prior of approximately $0.85$)}{figure.5}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces Feasible-region posterior risk updating: posterior exceedance probability $P(\sigma >\SI {131}{MPa}\mid \mathrm  {obs})$ for 10~high-stress cases with true stress 133--\SI {194}{MPa} (all above the \SI {131}{MPa} design threshold). Global prior exceedance probability: $\approx 0.85$. }}{10}{table.5}\protected@file@percent }
\newlabel{tab:extreme}{{5}{10}{Feasible-region posterior risk updating: posterior exceedance probability $P(\sigma >\SI {131}{MPa}\mid \mathrm {obs})$ for 10~high-stress cases with true stress 133--\SI {194}{MPa} (all above the \SI {131}{MPa} design threshold). Global prior exceedance probability: $\approx 0.85$}{table.5}{}}
