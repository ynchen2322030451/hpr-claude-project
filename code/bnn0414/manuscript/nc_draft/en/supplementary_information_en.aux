\@writefile{toc}{\contentsline {section}{\numberline {1}Supplementary Figures}{2}{section.1}\protected@file@percent }
\newlabel{sec:figures}{{1}{2}{Supplementary Figures}{section.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Fig.~S1~|~BNN surrogate workflow.} Schematic of the end-to-end probabilistic analysis framework. The BNN surrogate is trained on coupled OpenMC--FEniCS data and produces a posterior predictive distribution. This single distribution serves as the shared probabilistic layer for forward uncertainty propagation, Sobol sensitivity attribution, and MCMC posterior calibration, without retraining between analyses.}}{2}{figure.caption.1}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:S1}{{1}{2}{\textbf {Fig.~S1~|~BNN surrogate workflow.} Schematic of the end-to-end probabilistic analysis framework. The BNN surrogate is trained on coupled OpenMC--FEniCS data and produces a posterior predictive distribution. This single distribution serves as the shared probabilistic layer for forward uncertainty propagation, Sobol sensitivity attribution, and MCMC posterior calibration, without retraining between analyses}{figure.caption.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Fig.~S2~|~Model validation: parity and residual analysis.} Predicted versus true values and residual distributions for primary outputs across both BNN variants (501 test samples). Shaded regions show the 90\% predictive interval.}}{3}{figure.caption.2}\protected@file@percent }
\newlabel{fig:S2}{{2}{3}{\textbf {Fig.~S2~|~Model validation: parity and residual analysis.} Predicted versus true values and residual distributions for primary outputs across both BNN variants (501 test samples). Shaded regions show the 90\% predictive interval}{figure.caption.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Fig.~S3~|~Physics consistency and uncertainty decomposition.} (\textbf  {A})~Monotonicity violation rates for 15 input--output pairs across both BNN variants; high-confidence pairs achieve zero violations. (\textbf  {B})~Epistemic vs.\ aleatoric variance decomposition. Aleatoric uncertainty dominates across all outputs (58--90\% of total variance).}}{4}{figure.caption.3}\protected@file@percent }
\newlabel{fig:S3}{{3}{4}{\textbf {Fig.~S3~|~Physics consistency and uncertainty decomposition.} (\textbf {A})~Monotonicity violation rates for 15 input--output pairs across both BNN variants; high-confidence pairs achieve zero violations. (\textbf {B})~Epistemic vs.\ aleatoric variance decomposition. Aleatoric uncertainty dominates across all outputs (58--90\% of total variance)}{figure.caption.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Fig.~S4~|~Out-of-distribution (OOD) coverage and epistemic uncertainty.} 90\% predictive interval coverage for in-distribution versus four feature-tail subsets. Stress retains coverage above 0.75 across all tails. \ensuremath  {k_{\mathrm  {eff}}}{} coverage degrades substantially on the \ensuremath  {\alpha _{\mathrm  {base}}}{} tail ($R^2$ drops to approximately 0.29), indicating that the Sobol and posterior conclusions for \ensuremath  {k_{\mathrm  {eff}}}{} are valid only within the training range of this dominant parameter. Elevated epistemic ratios on the \ensuremath  {\alpha _{\mathrm  {base}}}{} tail confirm that the BNN correctly signals increased model uncertainty outside the training domain.}}{5}{figure.caption.4}\protected@file@percent }
\newlabel{fig:S4}{{4}{5}{\textbf {Fig.~S4~|~Out-of-distribution (OOD) coverage and epistemic uncertainty.} 90\% predictive interval coverage for in-distribution versus four feature-tail subsets. Stress retains coverage above 0.75 across all tails. \keff {} coverage degrades substantially on the \abase {} tail ($R^2$ drops to approximately 0.29), indicating that the Sobol and posterior conclusions for \keff {} are valid only within the training range of this dominant parameter. Elevated epistemic ratios on the \abase {} tail confirm that the BNN correctly signals increased model uncertainty outside the training domain}{figure.caption.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Fig.~S5~|~Sobol index convergence with sample size.} First-order Sobol index $S_1$ as a function of sample size $N_S$ (256 to 4096) for stress and \ensuremath  {k_{\mathrm  {eff}}}{}, with 90\% CI bands across 50 replications. Indices stabilise by $N_S = 2048$, confirming convergence at the chosen $N_S = 4096$.}}{6}{figure.caption.5}\protected@file@percent }
\newlabel{fig:S5}{{5}{6}{\textbf {Fig.~S5~|~Sobol index convergence with sample size.} First-order Sobol index $S_1$ as a function of sample size $N_S$ (256 to 4096) for stress and \keff {}, with 90\% CI bands across 50 replications. Indices stabilise by $N_S = 2048$, confirming convergence at the chosen $N_S = 4096$}{figure.caption.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {Fig.~S6~|~Detailed Sobol sensitivity analysis.} First-order and total-order Sobol indices for all eight material parameters across all five primary outputs, showing the dominance of \ensuremath  {E_{\mathrm  {intercept}}}{} for stress and \ensuremath  {\alpha _{\mathrm  {base}}}{} for \ensuremath  {k_{\mathrm  {eff}}}{}.}}{6}{figure.caption.6}\protected@file@percent }
\newlabel{fig:S6}{{6}{6}{\textbf {Fig.~S6~|~Detailed Sobol sensitivity analysis.} First-order and total-order Sobol indices for all eight material parameters across all five primary outputs, showing the dominance of \Eint {} for stress and \abase {} for \keff {}}{figure.caption.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces \textbf  {Fig.~S7~|~Prior sensitivity analysis.} Posterior marginal distributions for the four calibrated parameters under six prior configurations: canonical, diffuse ($2\times $), tight ($0.5\times $), flat (uniform), shift$_{+}$ ($\mu + 0.5\sigma $), shift$_{-}$ ($\mu - 0.5\sigma $). The tight prior over-constrains the posterior, reducing coverage to 50--83\% (Table~S10).}}{7}{figure.caption.7}\protected@file@percent }
\newlabel{fig:S7}{{7}{7}{\textbf {Fig.~S7~|~Prior sensitivity analysis.} Posterior marginal distributions for the four calibrated parameters under six prior configurations: canonical, diffuse ($2\times $), tight ($0.5\times $), flat (uniform), shift$_{+}$ ($\mu + 0.5\sigma $), shift$_{-}$ ($\mu - 0.5\sigma $). The tight prior over-constrains the posterior, reducing coverage to 50--83\% (Table~S10)}{figure.caption.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces \textbf  {Fig.~S8~|~Observation noise sensitivity.} Posterior width and acceptance rate as a function of assumed observation noise fraction (0.5\%--10\%). Posterior standard deviations increase monotonically; acceptance rates increase appropriately as the likelihood broadens (Table~S11).}}{7}{figure.caption.8}\protected@file@percent }
\newlabel{fig:S8}{{8}{7}{\textbf {Fig.~S8~|~Observation noise sensitivity.} Posterior width and acceptance rate as a function of assumed observation noise fraction (0.5\%--10\%). Posterior standard deviations increase monotonically; acceptance rates increase appropriately as the likelihood broadens (Table~S11)}{figure.caption.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces \textbf  {Fig.~S9~|~Data efficiency and computational cost.} Test RMSE and $R^2$ as a function of training set size for the physics-regularized BNN. Near-saturated performance is achieved at 25\% data utilisation (507 training samples; Table~S12).}}{8}{figure.caption.9}\protected@file@percent }
\newlabel{fig:S9}{{9}{8}{\textbf {Fig.~S9~|~Data efficiency and computational cost.} Test RMSE and $R^2$ as a function of training set size for the physics-regularized BNN. Near-saturated performance is achieved at 25\% data utilisation (507 training samples; Table~S12)}{figure.caption.9}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces \textbf  {Fig.~S10~|~External baseline calibration comparison.} Calibration curves comparing BNN, MC-Dropout and deep ensemble across primary outputs. The BNN achieves substantially better probabilistic calibration (ECE 0.027 vs.\ 0.18--0.19) on temperature outputs.}}{8}{figure.caption.10}\protected@file@percent }
\newlabel{fig:S10}{{10}{8}{\textbf {Fig.~S10~|~External baseline calibration comparison.} Calibration curves comparing BNN, MC-Dropout and deep ensemble across primary outputs. The BNN achieves substantially better probabilistic calibration (ECE 0.027 vs.\ 0.18--0.19) on temperature outputs}{figure.caption.10}{}}
