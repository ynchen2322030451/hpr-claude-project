\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Sobol sensitivity analysis.} First-order and total-order indices for stress and \ensuremath {k_{\mathrm  {eff}}}{} reveal two largely separate physical pathways: the elastic-constitutive pathway (dominated by \ensuremath {E_{\mathrm  {intercept}}}{}) for stress, and the thermal-expansion pathway (dominated by \ensuremath {\alpha _{\mathrm  {base}}}{}) for \ensuremath {k_{\mathrm  {eff}}}{}.}}{9}{figure.caption.7}\protected@file@percent }
\newlabel{fig:sobol}{{4}{9}{\textbf {Sobol sensitivity analysis.} First-order and total-order indices for stress and \keff {} reveal two largely separate physical pathways: the elastic-constitutive pathway (dominated by \Eint {}) for stress, and the thermal-expansion pathway (dominated by \abase {}) for \keff {}}{figure.caption.7}{}}
